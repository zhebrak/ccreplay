{
  "name": "@zhebrak/ccreplay",
  "version": "0.2.0",
  "description": "Terminal replay videos of Claude Code sessions",
  "type": "module",
  "bin": {
    "ccreplay": "dist/cli.js"
  },
  "files": [
    "dist/",
    "!dist/**/*.js.map",
    "fonts/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "smoke-test": "bash scripts/smoke-test.sh",
    "generate-demo": "bash scripts/generate-demo.sh",
    "start": "node dist/cli.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@inquirer/select": "^4.2.0",
    "@napi-rs/canvas": "^0.1.65",
    "ffmpeg-static": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhebrak/ccreplay.git"
  },
  "author": "Alex Zhebrak",
  "homepage": "https://github.com/zhebrak/ccreplay",
  "bugs": {
    "url": "https://github.com/zhebrak/ccreplay/issues"
  },
  "keywords": [
    "claude", "claude-code", "terminal", "replay",
    "video", "session", "recording", "mp4"
  ]
}
